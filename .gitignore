# Terraform bootstrap — exclude everything except main.tf
terraform/bootstrap/*
!terraform/bootstrap/main.tf

# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfplan
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# Lambda zip artifacts (generated by Terraform archive_file)
lambda/**/*.zip

# Node / React chatbot
chatbot/node_modules/
chatbot/dist/

# Streaming Lambda dependencies (installed in CI before terraform apply)
lambda/stream_agent/node_modules/

# macOS / Windows
.DS_Store
Thumbs.db
